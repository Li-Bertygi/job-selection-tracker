aws_region  = "ap-northeast-1"
project_name = "job-selection-tracker"
environment = "prod"

github_repository    = "Li-Bertygi/job-selection-tracker"
github_deploy_branch = "main"

frontend_repo_name = "job-selection-tracker-frontend"
backend_repo_name  = "job-selection-tracker-backend"

